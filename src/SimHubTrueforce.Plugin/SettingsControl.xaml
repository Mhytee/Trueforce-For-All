<UserControl x:Class="SimHubTrueforce.Plugin.SettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             d:DesignHeight="600" d:DesignWidth="700">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <!-- Header -->
            <TextBlock Text="SimHub Trueforce" FontSize="22" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBlock Text="Logitech Trueforce haptics for G PRO / RS50 wheels."
                       FontSize="13" Opacity="0.7" Margin="0,0,0,20" TextWrapping="Wrap"/>

            <!-- Section: Status -->
            <Border BorderBrush="#444" BorderThickness="0,0,0,1" Padding="0,0,0,8" Margin="0,0,0,12">
                <TextBlock Text="Status" FontSize="14" FontWeight="SemiBold"/>
            </Border>
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Wheel:"  Opacity="0.7"/>
                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="WheelText"  Text="(checking...)"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Stream:" Opacity="0.7" Margin="0,4,0,0"/>
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="StreamText" Text="(checking...)" Margin="0,4,0,0"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Active sources:" Opacity="0.7" Margin="0,4,0,0"/>
                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="VoicesText"   Text="0"          Margin="0,4,0,0"/>
            </Grid>

            <!-- Section: Master -->
            <Border BorderBrush="#444" BorderThickness="0,0,0,1" Padding="0,0,0,8" Margin="0,0,0,12">
                <TextBlock Text="Master" FontSize="14" FontWeight="SemiBold"/>
            </Border>
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Master gain:" VerticalAlignment="Center" Opacity="0.7"/>
                <Slider     Grid.Column="1" x:Name="MasterGainSlider"
                            Minimum="0" Maximum="2.0" SmallChange="0.05" LargeChange="0.1"
                            TickFrequency="0.25" IsSnapToTickEnabled="False"
                            ValueChanged="MasterGainSlider_ValueChanged"
                            VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" x:Name="MasterGainText" VerticalAlignment="Center"
                           HorizontalAlignment="Right" Text="0.50"/>
            </Grid>

            <!-- Section: Audio capture -->
            <Border BorderBrush="#444" BorderThickness="0,0,0,1" Padding="0,0,0,8" Margin="0,0,0,12">
                <TextBlock Text="Audio capture (game audio → wheel)" FontSize="14" FontWeight="SemiBold"/>
            </Border>
            <CheckBox x:Name="AudioEnabledCheck" Content="Enable audio capture"
                      Margin="0,0,0,12"
                      Checked="AudioEnabled_Changed" Unchecked="AudioEnabled_Changed"/>
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Gain:" VerticalAlignment="Center" Opacity="0.7"/>
                <Slider     Grid.Column="1" x:Name="AudioGainSlider"
                            Minimum="0" Maximum="3.0" SmallChange="0.05" LargeChange="0.25"
                            TickFrequency="0.5" IsSnapToTickEnabled="False"
                            ValueChanged="AudioGainSlider_ValueChanged"
                            VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" x:Name="AudioGainText" VerticalAlignment="Center"
                           HorizontalAlignment="Right" Text="1.00"/>
            </Grid>
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Level:" VerticalAlignment="Center" Opacity="0.7"/>
                <ProgressBar Grid.Column="1" x:Name="AudioLevelMeter" Minimum="0" Maximum="1"
                             Height="14" Foreground="#4CAF50"/>
            </Grid>
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Status:" VerticalAlignment="Center" Opacity="0.7"/>
                <TextBlock Grid.Column="1" x:Name="CaptureStatusText" Text="Idle"
                           VerticalAlignment="Center" TextWrapping="Wrap"/>
            </Grid>
            <TextBlock TextWrapping="Wrap" Opacity="0.6" FontSize="12" Margin="0,0,0,20">
                Per-process loopback: only the running game's audio drives the wheel. Capture starts
                automatically when SimHub detects a supported game and re-targets when the game changes.
            </TextBlock>
        </StackPanel>
    </ScrollViewer>
</UserControl>
